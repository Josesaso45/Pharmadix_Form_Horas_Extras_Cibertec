<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/apk/res-tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121320"
    tools:context=".ui.registro.CustomScannerActivity">

    <!-- Escáner base de ZXing -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/zxing_barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_use_texture_view="true"
        app:zxing_viewfinder_laser="@color/pharmadix_primary"
        app:zxing_viewfinder_mask="#99121320" />

    <!-- Top Navigation Custom -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_top_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_cerrar_escaner"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHARMADIX TIMES"
                android:textColor="@color/pharmadix_primary_light"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QR Gafete Scanner"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Botón Cerrar -->
        <ImageButton
            android:id="@+id/btn_cerrar_escaner"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circulo_oscuro_bg"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Instrucción debajo del escaner -->
    <TextView
        android:id="@+id/tv_instruccion_qr"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Apunta al código QR del gafete del operario"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintTop_toBottomOf="@id/layout_top_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Panel de Acciones Bottom -->
    <LinearLayout
        android:id="@+id/layout_bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <!-- Linterna -->
            <ImageButton
                android:id="@+id/btn_flash"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circulo_oscuro_bg"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="@color/white"
                android:layout_marginEnd="32dp" />

            <!-- Lente Decorativo Centro -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circulo_primario_bg"
                android:elevation="8dp">
                
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Cambiar Cámara -->
            <ImageButton
                android:id="@+id/btn_switch_cam"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circulo_oscuro_bg"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white"
                android:layout_marginStart="32dp" />
        </LinearLayout>

        <!-- Buscar Manualmente -->
        <Button
            android:id="@+id/btn_manual_search_escaner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buscar manualmente"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="#66121320"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="@color/pharmadix_primary_light"
            app:cornerRadius="12dp"
            app:strokeColor="#4D9E9E9E"
            app:strokeWidth="1dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
