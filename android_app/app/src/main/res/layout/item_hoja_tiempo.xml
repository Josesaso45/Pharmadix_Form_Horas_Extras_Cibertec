<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/apk/res-tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/divider_color"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="?attr/selectableItemBackground">

        <!-- Lote Activo (Subtítulo superior) -->
        <TextView
            android:id="@+id/tv_label_lote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOTE ACTIVO"
            android:textColor="@color/pharmadix_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ID Lote (Título) -->
        <TextView
            android:id="@+id/tv_hoja_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="HT-2024-001"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_label_lote" />

        <!-- Producto (Secundario) -->
        <TextView
            android:id="@+id/tv_producto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Amoxicilina 500mg"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_hoja_id" />

        <!-- Badge Estado (Ej: ABIERTA) -->
        <TextView
            android:id="@+id/badge_estado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="ABIERTA"
            tools:backgroundTint="@color/pharmadix_green"
            android:background="@drawable/hoja_estado_bg"
            android:textColor="@color/pharmadix_green"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textAllCaps="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Space
            android:id="@+id/spacer"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_producto" />

        <!-- Badge Turno -->
        <TextView
            android:id="@+id/badge_turno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="MAÑANA"
            android:background="@drawable/turno_bg"
            android:textColor="@color/pharmadix_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textAllCaps="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/spacer" />

        <!-- Continuar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/badge_turno"
            app:layout_constraintBottom_toBottomOf="@id/badge_turno">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Continuar"
                android:textColor="@color/pharmadix_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_baseline_arrow_forward_ios_24"
                app:tint="@color/pharmadix_primary" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
