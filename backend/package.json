{
    "name": "pharmadix-backend",
    "version": "1.0.0",
    "description": "API REST Pharmadix Times - Fastify + Prisma + PostgreSQL",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "migrate": "prisma migrate deploy",
        "seed": "ts-node prisma/seed.ts",
        "db:reset": "prisma migrate reset --force && ts-node prisma/seed.ts"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@fastify/jwt": "^8.0.1",
        "@prisma/client": "^5.10.2",
        "bcryptjs": "^2.4.3",
        "fastify": "^4.26.2",
        "pino-pretty": "^11.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^20.11.25",
        "prisma": "^5.10.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.2"
    }
}